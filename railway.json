{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22", "pnpm"]
        },
        "install": {
          "cmds": ["pnpm install"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd apps/world-server && npx tsx src/index.ts"
  }
}
